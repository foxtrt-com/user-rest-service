{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": "5672"
  },
  "Jwt": {
    "SecretKey": "REPLACE_WITH_ACTUAL_SECRET_KEY",
